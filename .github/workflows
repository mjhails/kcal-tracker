.github/workflows.github/workflowsname: Send daily reminders

on:
  schedule:
    - cron: "*/5 * * * *" # every 5 minutes, all day — the script itself decides who (if anyone) actually gets pinged
  workflow_dispatch: {} # lets you also trigger it manually from the Actions tab, handy for testing

jobs:
  send-reminders:
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4

      - uses: actions/setup-node@v4
        with:
          node-version: 20

      - name: Install script dependencies
        working-directory: scripts/send-reminders
        run: npm install

      - name: Run reminder check
        working-directory: scripts/send-reminders
        env:
          FIREBASE_SERVICE_ACCOUNT: ${{ secrets.FIREBASE_SERVICE_ACCOUNT }}
          VAPID_PUBLIC_KEY: ${{ secrets.VAPID_PUBLIC_KEY }}
          VAPID_PRIVATE_KEY: ${{ secrets.VAPID_PRIVATE_KEY }}
          VAPID_SUBJECT: ${{ secrets.VAPID_SUBJECT }}
        run: node index.js
